---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import WhyUs from '../components/WhyUs.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import '../styles/global.css';

const title = 'Jekakuaa — Consultoría TI y soluciones digitales';
const description =
  'Acompañamos a empresas paraguayas en su transformación digital con consultoría TI, desarrollo a medida y soluciones digitales a la medida. Contactanos.';
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <Hero />
    <Services />
    <About />
    <WhyUs />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFab />
</Layout>
