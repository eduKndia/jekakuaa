---
// Header para páginas legales — mismo estilo que la landing, sin menú de navegación
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-border shadow-sm">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group" aria-label="Jekakuaa - Inicio">
      <span
        class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-sm transition-transform group-hover:scale-105"
        aria-hidden="true"
      >
        J
      </span>
      <span class="text-lg font-semibold text-primary-dark tracking-tight">Jekakuaa</span>
    </a>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-accent transition-all duration-300 shadow-sm hover:shadow"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7" /><path d="M19 12H5" />
      </svg>
      Volver al inicio
    </a>
  </nav>
</header>
