<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/80 backdrop-blur-md border-b border-transparent"
>
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#inicio" class="flex items-center gap-2 group" aria-label="Jekakuaa - Inicio">
      <span
        class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white font-bold text-sm transition-transform group-hover:scale-105"
        aria-hidden="true"
      >
        J
      </span>
      <span class="text-lg font-semibold text-primary-dark tracking-tight">Jekakuaa</span>
    </a>

    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-text">
      <li><a href="#inicio" class="hover:text-primary transition-colors">Inicio</a></li>
      <li><a href="#servicios" class="hover:text-primary transition-colors">Servicios</a></li>
      <li><a href="#nosotros" class="hover:text-primary transition-colors">Nosotros</a></li>
      <li><a href="#contacto" class="hover:text-primary transition-colors">Contacto</a></li>
    </ul>

    <a
      href="#contacto"
      class="hidden md:inline-flex items-center px-5 py-2 rounded-lg bg-primary text-white text-sm font-medium hover:bg-accent transition-all duration-300 shadow-sm hover:shadow"
    >
      Contactanos
    </a>

    <details class="md:hidden relative group">
      <summary
        class="list-none cursor-pointer p-2 rounded-md hover:bg-primary-very-light transition-colors"
        aria-label="Abrir menú"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6 text-primary-dark"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </summary>
      <div
        class="absolute right-0 top-12 w-56 bg-white border border-gray-border rounded-xl shadow-lg p-2 origin-top-right"
      >
        <ul class="flex flex-col text-sm font-medium text-gray-text">
          <li>
            <a
              href="#inicio"
              class="block px-4 py-2.5 rounded-lg hover:bg-primary-very-light hover:text-primary transition-colors"
              >Inicio</a
            >
          </li>
          <li>
            <a
              href="#servicios"
              class="block px-4 py-2.5 rounded-lg hover:bg-primary-very-light hover:text-primary transition-colors"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#nosotros"
              class="block px-4 py-2.5 rounded-lg hover:bg-primary-very-light hover:text-primary transition-colors"
              >Nosotros</a
            >
          </li>
          <li>
            <a
              href="#contacto"
              class="block px-4 py-2.5 rounded-lg hover:bg-primary-very-light hover:text-primary transition-colors"
              >Contacto</a
            >
          </li>
          <li class="mt-1 pt-1 border-t border-gray-border">
            <a
              href="#contacto"
              class="block px-4 py-2.5 rounded-lg bg-primary text-white text-center hover:bg-accent transition-colors"
              >Contactanos</a
            >
          </li>
        </ul>
      </div>
    </details>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  const updateHeader = () => {
    if (!header) return;
    if (window.scrollY > 8) {
      header.classList.add('shadow-sm', 'border-gray-border');
      header.classList.remove('border-transparent');
    } else {
      header.classList.remove('shadow-sm', 'border-gray-border');
      header.classList.add('border-transparent');
    }
  };
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });
</script>
